{
  "name": "mlx-node",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples"
  ],
  "type": "module",
  "scripts": {
    "build": "yarn build:native && yarn build:ts",
    "build:native": "yarn workspace @mlx-node/core build",
    "build:ts": "tsc -b",
    "clean": "rm -rf packages/*/dist",
    "lint": "vite lint --type-aware --type-check",
    "format": "vite fmt",
    "typecheck": "tsc -b",
    "download:gsm8k": "yarn oxnode scripts/download-gsm8k.ts",
    "download:qwen3": "yarn oxnode scripts/download-model.ts"
  },
  "devDependencies": {
    "@ast-grep/napi": "^0.40.5",
    "@huggingface/hub": "^2.7.2",
    "@inquirer/prompts": "^8.2.0",
    "@mlx-node/lm": "workspace:*",
    "@mlx-node/trl": "workspace:*",
    "@napi-rs/cli": "^3.5.1",
    "@napi-rs/keyring": "^1.2.0",
    "@napi-rs/simple-git": "^0.1.22",
    "@oxc-node/cli": "^0.0.35",
    "@oxc-node/core": "^0.0.35",
    "@std/toml": "npm:@jsr/std__toml@^1.0.11",
    "@types/node": "^25.0.10",
    "octokit": "^5.0.5",
    "oxc-parser": "^0.110.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "resolutions": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "yarn@4.12.0"
}
