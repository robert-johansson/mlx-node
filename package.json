{
  "name": "mlx-node",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples"
  ],
  "type": "module",
  "scripts": {
    "build": "yarn build:native && yarn build:ts",
    "build:native": "yarn workspace @mlx-node/core build",
    "build:ts": "tsc -b",
    "clean": "rm -rf packages/*/dist",
    "lint": "vp lint",
    "format": "vp fmt",
    "test": "vp test",
    "typecheck": "tsc -b",
    "mlx": "oxnode packages/cli/src/cli.ts"
  },
  "devDependencies": {
    "@ast-grep/napi": "^0.41.1",
    "@mlx-node/cli": "workspace:*",
    "@mlx-node/lm": "workspace:*",
    "@mlx-node/trl": "workspace:*",
    "@mlx-node/vlm": "workspace:*",
    "@napi-rs/cli": "^3.5.1",
    "@napi-rs/simple-git": "^0.1.22",
    "@oxc-node/cli": "^0.0.35",
    "@oxc-node/core": "^0.0.35",
    "@std/toml": "npm:@jsr/std__toml@^1.0.11",
    "@types/node": "^25.5.0",
    "octokit": "^5.0.5",
    "oxc-parser": "^0.118.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "resolutions": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "yarn@4.13.0"
}
