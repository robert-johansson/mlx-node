{
  "name": "@mlx-node/core",
  "version": "0.0.0",
  "description": "Internal native bindings - import from @mlx-node/lm or @mlx-node/trl instead",
  "files": [
    "index.cjs",
    "index.d.cts"
  ],
  "type": "module",
  "main": "./index.cjs",
  "types": "./index.d.cts",
  "exports": {
    ".": {
      "types": "./index.d.cts",
      "import": "./index.cjs",
      "require": "./index.cjs"
    }
  },
  "scripts": {
    "build": "oxnode ./build.ts --release",
    "prepublishOnly": "napi prepublish -t npm --no-gh-release",
    "preversion": "oxnode ./build.ts && git add .",
    "version": "napi version"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.1",
    "@oxc-node/cli": "^0.0.35",
    "oxfmt": "^0.40.0"
  },
  "napi": {
    "binaryName": "mlx-core",
    "targets": [
      "aarch64-apple-darwin"
    ]
  }
}
