  ngramSize?: number;
  /** EOS token ID (generation stops when this is generated) */
  eosTokenId?: number;
  /** Whether to return log probabilities (always true for GRPO) */
  returnLogprobs?: boolean;
  /**
   * Prefill step size for chunked processing of long prompts (default: 2048)
